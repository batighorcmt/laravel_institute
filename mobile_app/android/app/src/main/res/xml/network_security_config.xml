<?xml version="1.0" encoding="utf-8"?>
<!--
  Cleartext (HTTP) traffic is disabled by default for the whole app.
  It is only re-enabled for local development hosts used when pointing
  the app at a Laravel dev server (see lib/core/config/env.dart and
  README.md's dart define API_BASE_URL examples). All other
  traffic (including the production https://institute.batighorbd.com
  host) must use HTTPS.
-->
<network-security-config>
    <domain-config cleartextTrafficPermitted="true">
        <!-- Android emulator's alias for the host machine's localhost -->
        <domain includeSubdomains="false">10.0.2.2</domain>
        <!-- Physical device / desktop testing against a local dev server -->
        <domain includeSubdomains="false">localhost</domain>
        <domain includeSubdomains="false">127.0.0.1</domain>
    </domain-config>

    <base-config cleartextTrafficPermitted="false" />
</network-security-config>
